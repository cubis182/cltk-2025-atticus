dim1 <- as.character(summary(pca)$importance[2] * 100)
dim2 <- as.character(summary(pca)$importance[5] * 100)
cluster_main <- fviz_cluster(kmeans_basic_cluster,
data = df_clust,
palette = palette,
geom = geom,
ellipse.type = ellipse.type,
ggtheme = ggtheme
) + geom_text_repel(aes(label=rownames(df_clust)), vjust="inward", hjust="inward", max.overlaps = 14, size=2, seed = 12927) + labs(x = paste("Dim1", dim1, "(Left = More 1st/2nd person, personal pronouns, Right = More Ablative nouns, Passive Verbs, participles)"), y = paste("Dim2", dim2, "(Up = more particles, Down = fewer particles)"), title = "K-means clustering applied to PHI Latin Texts, k=4") + theme(axis.title = element_text(size = 8))
cluster_main
ggsave(filename = "Images/cluster-diagram-kmeans-all-cicero.png", dpi="print")
